doctype html
html(lang="ru")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Список пользователей
  body
    h1 Список пользователей
    ul
      each user in users
        li 
          strong ID: #{user.id}, 
          | Имя: #{user.name}, 
          | Email: #{user.email}
    br
    a(href="/users/create") Создать пользователя